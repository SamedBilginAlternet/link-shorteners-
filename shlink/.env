# Shlink domain (without https://) — örn: lnk.alternet.com.tr
SHLINK_DOMAIN=localhost:8080

# HTTPS aktif mi? (true/false)
SHLINK_HTTPS=false

# PostgreSQL ayarları
DB_NAME=shlink
DB_USER=shlink
DB_PASSWORD=shlink_guclu_sifre_degistir

# İlk API key (dashboard bağlantısı için sakla)
SHLINK_API_KEY=degistir-bunu-uzun-rastgele-string-yap

# Uptime Kuma admin bilgileri (ilk açılışta oluşturduğun)
KUMA_USER=admin
KUMA_PASS=degistir_kuma_sifren

# Shlink → Kuma sync aralığı (saniye)
POLL_INTERVAL=60
